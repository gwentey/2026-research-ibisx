  "info": {
    "description": "API d'IBIS-X v2 — plateforme d'accompagnement ML de bout en bout (sélection éthique de datasets, pipeline guidé, explicabilité).",
    "title": "IBIS-X API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/auth/forgot-password": {
      "post": {
        "description": "Répond toujours 204 (pas d'énumération). Sans SMTP le lien est loggé (dev).",
        "operationId": "forgotPassword",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ForgotPasswordRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Forgot Password",
        "tags": [
          "auth"
        ]
      }
    },
    "/api/v1/auth/google/authorize": {
      "get": {
        "operationId": "googleAuthorize",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GoogleAuthorizeResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Google Authorize",
        "tags": [
          "auth"
        ]
      }
    },
    "/api/v1/auth/google/exchange": {
      "post": {
        "description": "Échange le code Google, valide l'id_token, émet NOS jetons (ADR-003).",
        "operationId": "googleExchange",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GoogleExchangeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Google Exchange",
        "tags": [
          "auth"
        ]
      }
    },
