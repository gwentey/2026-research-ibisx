{
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthReport": {
        "properties": {
          "database": {
            "enum": [
              "ok",
              "error"
            ],
            "title": "Database",
            "type": "string"
          },
          "redis": {
            "enum": [
              "ok",
              "error"
            ],
            "title": "Redis",
            "type": "string"
          },
          "status": {
            "enum": [
              "ok",
              "degraded"
            ],
            "title": "Status",
            "type": "string"
          },
          "storage": {
            "enum": [
              "ok",
              "error"
            ],
            "title": "Storage",
            "type": "string"
          },
          "version": {
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "status",
          "database",
          "redis",
          "storage",
          "version"
        ],
        "title": "HealthReport",
        "type": "object"
      },
      "JobKind": {
        "enum": [
          "training",
          "explanation",
          "chat",
          "import",
          "guide",
          "maintenance"
        ],
        "title": "JobKind",
        "type": "string"
      },
      "JobRead": {
        "properties": {
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "error_code": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Code"
          },
          "finished_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Finished At"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "kind": {
            "$ref": "#/components/schemas/JobKind"
          },
          "message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Message"
          },
          "progress": {
            "title": "Progress",
            "type": "integer"
          },
          "queue": {
            "title": "Queue",
            "type": "string"
          },
          "ref_id": {
            "anyOf": [
              {
                "format": "uuid",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ref Id"
          },
          "started_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Started At"
          },
          "status": {
            "$ref": "#/components/schemas/JobStatus"
          },
          "user_id": {
            "anyOf": [
              {
                "format": "uuid",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "User Id"
          }
        },
        "required": [
          "id",
          "kind",
          "status",
          "user_id",
          "ref_id",
          "queue",
          "progress",
          "error_code",
          "message",
          "created_at",
          "started_at",
          "finished_at"
        ],
        "title": "JobRead",
        "type": "object"
      },
      "JobStatus": {
        "enum": [
          "pending",
          "running",
          "completed",
          "failed",
          "cancelled"
        ],
        "title": "JobStatus",
        "type": "string"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "WorkerHealthReport": {
        "properties": {
          "status": {
            "enum": [
              "ok",
              "unavailable"
            ],
            "title": "Status",
            "type": "string"
          },
          "workers": {
            "items": {
              "type": "string"
            },
            "title": "Workers",
            "type": "array"
          }
        },
        "required": [
          "status",
          "workers"
        ],
        "title": "WorkerHealthReport",
        "type": "object"
      }
    }
  },
  "info": {
    "description": "API d'IBIS-X v2 — plateforme d'accompagnement ML de bout en bout (sélection éthique de datasets, pipeline guidé, explicabilité).",
    "title": "IBIS-X API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/health": {
      "get": {
        "operationId": "getHealth",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthReport"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Health",
        "tags": [
          "health"
        ]
      }
    },
    "/api/v1/health/worker": {
      "get": {
        "operationId": "getWorkerHealth",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkerHealthReport"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Worker Health",
        "tags": [
          "health"
        ]
      }
    },
    "/api/v1/jobs/smoke": {
      "post": {
        "description": "Job de démonstration du socle (progression 0→100 via le worker).\n\nIndisponible en production — sert uniquement à prouver la chaîne\nAPI → file → worker → BDD/pub-sub → SSE (JALONS.md J0).",
        "operationId": "startSmokeJob",
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobRead"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Start Smoke Job",
        "tags": [
          "jobs"
        ]
      }
    },
    "/api/v1/jobs/{job_id}": {
      "get": {
        "description": "Statut d'un job (repli polling — toujours disponible, ADR-007).",
        "operationId": "getJob",
        "parameters": [
          {
            "in": "path",
            "name": "job_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "title": "Job Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobRead"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Job",
        "tags": [
          "jobs"
        ]
      }
    },
    "/api/v1/jobs/{job_id}/events": {
      "get": {
        "description": "Flux SSE de progression d'un job : état courant immédiat, puis pub/sub Redis.\n\nSe termine de lui-même quand le job atteint un statut terminal.",
        "operationId": "streamJobEvents",
        "parameters": [
          {
            "in": "path",
            "name": "job_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "title": "Job Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Stream Job Events",
        "tags": [
          "jobs"
        ]
      }
    }
  }
}
