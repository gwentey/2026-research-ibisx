# ============================================================================
# IBIS-X v2 — variables d'environnement (ARCH §11)
# Copier en `.env` (JAMAIS commité) : cp .env.example .env
# Les valeurs marquées CHANGE-ME doivent être générées/renseignées.
# Rappel : toutes les clés de la v1 sont COMPROMISES — n'en réutiliser aucune.
# ============================================================================

# --- Général ---
ENVIRONMENT=dev                       # dev | test | production
LOG_LEVEL=INFO

# --- Base de données & broker (résolus automatiquement dans docker compose) ---
POSTGRES_PASSWORD=ibis                # CHANGE-ME en production
# DATABASE_URL=postgresql+psycopg://ibis:ibis@localhost:5432/ibis
# REDIS_URL=redis://localhost:6379/0

# --- Auth (ADR-003) ---
# Générer : python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE-ME-generate-a-random-256-bit-secret
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=

# --- Connexion Google (OIDC direct, gratuit — Google Cloud Console) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:3000/auth/google/callback

# --- Stockage (ADR-005) ---
STORAGE_BACKEND=local                 # local | s3
DATA_DIR=/data

# --- LLM : OpenRouter EXCLUSIVEMENT (ADR-006) ---
# Sans clé : la plateforme fonctionne à 100 % avec des fallbacks marqués is_fallback.
OPENROUTER_API_KEY=
LLM_MODEL=openai/gpt-5-mini
LLM_MAX_TOKENS=2000
LLM_TIMEOUT_SECONDS=60

# --- Import Kaggle (optionnel — le seed embarqué n'en a pas besoin) ---
KAGGLE_USERNAME=
KAGGLE_KEY=

# --- SMTP (optionnel — sans SMTP, le lien de reset est loggé en dev) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=IBIS-X <no-reply@ibisx.local>

# --- Quotas & crédits (CDC §3.3) ---
MAX_CONCURRENT_TRAININGS=3
MAX_DAILY_TRAININGS=20
DEFAULT_CREDITS=100
MAX_CHAT_QUESTIONS=5
CHAT_SESSION_TIMEOUT_HOURS=24
